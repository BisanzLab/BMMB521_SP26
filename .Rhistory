as.data.frame() %>%
rownames_to_column("SampleID")
data <- metadata %>%
select(SampleID, Cdifficile) %>%
left_join(features_df, by = "SampleID")
data
data <- metadata[,c("SampleID","Cdifficile")] %>%
select(SampleID, Cdifficile) %>%
left_join(features_df, by = "SampleID")
data$Cdifficile
data$Cdifficile <- factor(data$Cdifficile)
levels(data$Cdifficile) <- c("Negative", "Positive")
data$Cdifficile
ctrl <- trainControl(
method = "cv",
number = 10,
classProbs = TRUE,
summaryFunction = twoClassSummary
)
set.seed(123)
rf_model <- train(
Cdifficile ~ . - SampleID,
data = data,
method = "rf",
metric = "ROC",
trControl = ctrl,
importance = TRUE
)
rf_model
rf_model$results
varImp(rf_model)
library(pROC)
#load proc
roc_obj <- roc(rf_model$pred$obs, rf_model$pred$Positive)
rf_model
f_model$pred$obs
rf_model$pred$obs
ctrl <- trainControl(
method = "cv",
number = 10,
classProbs = TRUE,
summaryFunction = twoClassSummary,
savePredictions = "final"
)
set.seed(123)
rf_model <- train(
Cdifficile ~ . - SampleID,
data = data,
method = "rf",
metric = "ROC",
trControl = ctrl,
importance = TRUE
)
rf_model
rf_model$results
varImp(rf_model)
#load proc
roc_obj <- roc(rf_model$pred$obs, rf_model$pred$Positive)
plot(roc_obj, print.auc=TRUE)
